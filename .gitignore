# Build output
/bin/
*.exe
*.dll
*.so
*.dylib

# Test & profiling artifacts
*.test
*.prof
*.pprof
coverage.out

# Local CGO dev dependencies (SDL2, libwebp, ...) fetched by scripts/
/.deps/

# Editor noise
.vscode/
.idea/
*.swp

# Local release packages (CI artifacts are the shipping builds)
/dist/

# AppImage build scratch (scripts/build-appimage.sh)
/AppDir/
*.AppImage

# Flatpak generated manifest (scripts/build-flatpak.sh substitutes the template)
/packaging/flatpak/_build.yaml
*.flatpak
